---
import type { GetStaticPaths, Page } from "astro";
import PageLayout from "../layouts/PageLayout.astro";
import PostCard from "../components/PostCard.astro";
import Pagination from "../components/Pagination.astro";
import { getSortedPosts, type Post } from "../lib/posts";
import { SITE, PAGE_SIZE } from "../consts";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  return paginate(posts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<Post> };
---

<PageLayout
  isHome={true}
  pageTitle={SITE.title}
  pageSubtitle="Welcome to Daryl's Personal Space"
>
  {page.data.map((post, i) => <PostCard post={post} index={i} />)}

  <Pagination
    prev={page.url.prev}
    next={page.url.next}
    current={page.currentPage}
    total={page.lastPage}
  />
</PageLayout>
