---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, SOCIAL } from "../consts";
---

<BaseLayout title="About" pageTitle="About" pageSubtitle="A little about me">
  <div id="content-wrap" class="full">
    <main>
      <div class="about-card">
        <img class="about-avatar" src={SITE.avatar} alt={SITE.author} />
        <h1>{SITE.author}</h1>
        <p class="about-tag">
          Software Developer · IT Technician · Music lover · Lifelong learner
        </p>

        <p>
          Hi, I'm {SITE.author}. This is my personal corner of the web where I
          keep notes on front-end development, computer science coursework, and
          the occasional diary entry. My favorite music type is
          <strong>melodic progressive house</strong>.
        </p>

        <div class="about-social">
          {
            SOCIAL.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                style={`--c:${s.color}`}
                title={s.name}
              >
                <i class={s.icon} />
              </a>
            ))
          }
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .about-card {
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--card-box-shadow);
    padding: 2.5rem;
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .about-avatar {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  .about-card h1 {
    margin: 1rem 0 0.3rem;
  }
  .about-tag {
    color: var(--grey);
    margin-top: 0;
  }
  .about-card p {
    text-align: left;
    line-height: 1.9;
  }
  .about-social {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
    font-size: 1.5rem;
  }
  .about-social a {
    color: var(--grey);
  }
  .about-social a:hover {
    color: var(--c);
  }
</style>
