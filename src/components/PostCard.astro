---
import type { Post } from "../lib/posts";
import { postUrl } from "../lib/slug";
import { canonicalCategory } from "../lib/categories";
import { excerpt } from "../lib/excerpt";

interface Props { post: Post; index?: number }
const { post, index = 0 } = Astro.props;
const { title, date, categories, tags } = post.data;
const body = excerpt(post.body, 150);
const fmt = date.toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "numeric",
});
const reverse = index % 2 === 1;
---

<article class:list={["article-card", "fade-in", { reverse }]} style={`animation-delay:${index * 60}ms`}>
  {post.data.cover && (
    <a class="card-cover" href={postUrl(post.id)}>
      <img src={post.data.cover} alt={title} loading="lazy" />
    </a>
  )}
  <div class="card-body">
    <a class="card-title" href={postUrl(post.id)}>{title}</a>
    <div class="card-meta">
      <span><i class="far fa-calendar"></i> {fmt}</span>
      {categories.length > 0 && (
        <span>
          <i class="fas fa-folder-open"></i>
          {categories.map((c) => (
            <a href={`/categories/${canonicalCategory(c)}/`}>{canonicalCategory(c)}</a>
          ))}
        </span>
      )}
    </div>
    {body && <p class="card-excerpt">{body}</p>}
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map((t) => (
          <a href={`/tags/${t.trim()}/`} class="tag-pill"># {t.trim()}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .article-card {
    display: flex;
    overflow: hidden;
    margin-bottom: 1.2rem;
  }
  .article-card:hover {
    box-shadow: var(--card-hover-box-shadow);
  }
  .card-cover {
    flex: 0 0 45%;
    max-width: 45%;
    overflow: hidden;
  }
  .card-cover img {
    width: 100%;
    height: 100%;
    min-height: 200px;
    object-fit: cover;
    transition: transform 0.6s;
  }
  .card-cover:hover img {
    transform: scale(1.05);
  }
  .article-card.reverse {
    flex-direction: row-reverse;
  }
  .card-body {
    flex: 1;
    padding: 1.4rem 1.6rem;
    min-width: 0;
  }
  .card-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--font-color);
    line-height: 1.4;
    display: inline-block;
    margin-bottom: 0.4rem;
  }
  .card-title:hover {
    color: var(--theme-color);
  }
  .card-meta {
    color: var(--grey);
    font-size: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .card-meta i {
    margin-right: 0.25rem;
    color: var(--theme-color);
  }
  .card-meta a {
    color: var(--grey);
  }
  .card-meta a:hover {
    color: var(--theme-color);
  }
  .card-excerpt {
    color: var(--grey);
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0.4rem 0 0.8rem;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-pill {
    font-size: 0.78rem;
    color: var(--theme-color);
    background: rgba(73, 177, 245, 0.08);
    padding: 0.1rem 0.6rem;
    border-radius: 12px;
  }
  .tag-pill:hover {
    background: var(--theme-color);
    color: #fff;
  }
  @media (max-width: 768px) {
    .article-card,
    .article-card.reverse {
      flex-direction: column;
    }
    .card-cover {
      flex-basis: auto;
      max-width: 100%;
    }
    .card-cover img {
      min-height: 180px;
    }
  }
</style>
