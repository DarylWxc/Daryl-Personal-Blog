---
import { SITE } from "../consts";
import { postUrl } from "../lib/slug";
import {
  getCategories,
  getTags,
  getArchives,
  getRecentPosts,
} from "../lib/taxonomy";
import { getSortedPosts } from "../lib/posts";

const recent = await getRecentPosts(5);
const categories = (await getCategories()).slice(0, 8);
const tags = (await getTags()).slice(0, 40);
const archives = (await getArchives()).slice(0, 8);
const all = await getSortedPosts();
const postCount = all.length;
const lastUpdate = all[0]?.data.date;
const fmt = (d: Date) => d.toLocaleDateString("en-CA"); // YYYY-MM-DD
---

<aside id="aside-content">
  {/* Author card */}
  <div class="card-widget card-author">
    <img class="avatar" src={SITE.avatar} alt={SITE.author} />
    <div class="author-name">{SITE.author}</div>
    {SITE.subtitle && <div class="author-desc">{SITE.subtitle}</div>}
    <a class="author-btn" href={SITE.github} target="_blank" rel="noopener">
      <i class="fab fa-github"></i> Follow Me
    </a>
  </div>

  {/* Announcement */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-bullhorn"></i> Announcement</div>
    <div class="announcement">{SITE.announcement}</div>
  </div>

  {/* Recent posts */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-history"></i> Recent Posts</div>
    <ul class="card-list">
      {
        recent.map((p) => (
          <li>
            <a href={postUrl(p.id)}>{p.data.title}</a>
            <span class="muted">{fmt(p.data.date)}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {/* Categories */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-folder-open"></i> Categories</div>
    <ul class="card-list">
      {
        categories.map((c) => (
          <li>
            <a href={`/categories/${c.name}/`}>{c.name}</a>
            <span class="count">{c.count}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {/* Tags */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-tags"></i> Tags</div>
    <div class="tag-cloud">
      {
        tags.map((t) => (
          <a href={`/tags/${t.name}/`} class="tag-item">
            {t.name}
            <sup>{t.count}</sup>
          </a>
        ))
      }
    </div>
  </div>

  {/* Archives */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-archive"></i> Archives</div>
    <ul class="card-list">
      {
        archives.map((a) => (
          <li>
            <a href="/archives/">{a.label}</a>
            <span class="count">{a.posts.length}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {/* Web info */}
  <div class="card-widget">
    <div class="card-title"><i class="fas fa-chart-line"></i> Web Info</div>
    <ul class="card-list info">
      <li><span>Article :</span><span>{postCount}</span></li>
      {
        lastUpdate && (
          <li>
            <>
              <span>Last Push :</span>
              <span>{fmt(lastUpdate)}</span>
            </>
          </li>
        )
      }
    </ul>
  </div>
</aside>

<style>
  .card-widget {
    padding: 1.2rem 1.4rem;
    margin-bottom: 1.2rem;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-title i {
    color: var(--theme-color);
  }

  /* Author */
  .card-author {
    text-align: center;
  }
  .card-author .avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  .author-name {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0.6rem 0 0.2rem;
  }
  .author-desc {
    color: var(--grey);
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }
  .author-btn {
    display: inline-block;
    margin-top: 0.6rem;
    padding: 0.4rem 1.2rem;
    background: var(--theme-color);
    color: #fff;
    border-radius: 6px;
    font-size: 0.9rem;
  }
  .author-btn:hover {
    background: var(--theme-color-hover);
    color: #fff;
  }

  .announcement {
    color: var(--grey);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .card-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .card-list li a {
    color: var(--font-color);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-list li a:hover {
    color: var(--theme-color);
  }
  .card-list .muted,
  .card-list .count {
    color: var(--grey);
    font-size: 0.78rem;
    flex-shrink: 0;
  }
  .card-list.info li {
    color: var(--grey);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-item {
    font-size: 0.85rem;
    color: var(--font-color);
    padding: 0.1rem 0.3rem;
  }
  .tag-item:hover {
    color: var(--theme-color);
  }
  .tag-item sup {
    color: var(--grey);
    font-size: 0.65rem;
  }
</style>
