---
import { SITE } from "../consts";
const year = new Date().getFullYear();
const since = SITE.since < year ? `${SITE.since} - ${year}` : `${year}`;
---

<footer id="footer">
  <div class="footer-inner">
    <div class="footer-badges">
      <a
        target="_blank"
        rel="noopener"
        href="https://music.163.com/#/user/home?id=314486495"
      >
        <img
          alt="Music"
          src="https://img.shields.io/badge/Music-NetEase-%23FF0000"
        />
      </a>
      <a target="_blank" rel="noopener" href="https://github.com/DarylWxc">
        <img
          alt="Github"
          src="https://img.shields.io/badge/HomePage-Github-d021d6?style=flat&logo=GitHub"
        />
      </a>
      <a
        target="_blank"
        rel="noopener"
        href="https://steamcommunity.com/profiles/76561199093623098/"
      >
        <img
          alt="Steam"
          src="https://img.shields.io/badge/Community-Steam-171d25?logo=Steam"
        />
      </a>
    </div>
    <div class="footer-owner">
      &copy; {since}
      <a href="/">{SITE.author}</a>
    </div>
    <div class="footer-msg">
      Powered by <a href="https://astro.build" target="_blank" rel="noopener"
        >Astro</a
      >
      <span id="heartbeat"><i class="fas fa-heart"></i></span>
      Made with love
    </div>
  </div>
</footer>

<style>
  #footer {
    position: relative;
    background-image: linear-gradient(
      -225deg,
      #d6badf 0%,
      #b8dcff 28%,
      #58abf3 100%
    );
    color: #fff;
    padding: 2.5rem 1rem;
    text-align: center;
  }
  .footer-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .footer-badges img {
    display: block;
  }
  .footer-owner,
  .footer-msg {
    font-size: 0.9rem;
  }
  #footer a {
    color: #fff;
    font-weight: 600;
  }
  #footer a:hover {
    text-decoration: underline;
  }
  #heartbeat {
    color: #ff3333;
    display: inline-block;
    animation: heartbeat 1.33s infinite;
  }
  @keyframes heartbeat {
    0% {
      transform: scale(1);
    }
    14% {
      transform: scale(1.3);
    }
    28% {
      transform: scale(1);
    }
    42% {
      transform: scale(1.3);
    }
    70% {
      transform: scale(1);
    }
  }
</style>
